# CertMate Configuration
# Copy this file to .env and update the values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# Application Settings
HOST=0.0.0.0
PORT=8000

# Cloudflare API Token (optional: configurable via the web UI instead)
# Get this from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit, Zone:Zone:Read
CLOUDFLARE_TOKEN=

# PowerDNS (optional: configurable via the web UI instead)
# Set these to use PowerDNS as the DNS provider for ACME DNS-01 challenges.
# POWERDNS_API_URL should point to your PowerDNS server REST API endpoint.
POWERDNS_API_URL=
POWERDNS_API_KEY=

# API Bearer Token for authentication
# Use a strong, random token for security
# This token will be required for all API calls
API_BEARER_TOKEN=your_secure_api_token_here

# Optional: Set a secret key for session management
SECRET_KEY=your-secret-key-here

# Optional: Override the Let's Encrypt email set via the web UI
# LETSENCRYPT_EMAIL=
